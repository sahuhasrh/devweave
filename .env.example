# Backend (.env in backend/ directory)

# PostgreSQL (primary persistent storage)
DATABASE_URL="postgresql://devweave_user:devweave_password@localhost:5432/devweave"

# Redis (Pub/Sub, Socket.IO adapter, ephemeral presence/chat)
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS=false
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_secret_in_production
